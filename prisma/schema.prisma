generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ProductType {
  RAW_MATERIAL
  FINISHED_GOOD
  SUPPLY
  PACKAGING
}

enum LocationType {
  WAREHOUSE
  TRUCK
  PRODUCTION_LINE
  VIRTUAL
}

enum MovementType {
  PURCHASE_IN
  PRODUCTION_IN
  SALE_OUT
  CONSUMPTION_OUT
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  WASTE_OUT
  RETURN_IN
}

enum PreorderStatus {
  QUOTE
  PENDING
  CONFIRMED
  CANCELLED
  DISPATCHED
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  QUALITY_REVIEW
  CLOSED
  CANCELLED
}

enum DispatchStatus {
  SCHEDULED
  LOADED
  IN_ROUTE
  DELIVERED
  RETURN_REQUESTED
  RETURNED_TO_WAREHOUSE
  RESCHEDULED
  CANCELLED
}

model User {
  id                 String              @id @default(cuid())
  name               String              @db.VarChar(120)
  email              String              @unique @db.VarChar(160)
  passwordHash       String              @db.VarChar(255)
  area               String?             @db.VarChar(120)
  isActive           Boolean             @default(true)
  mustChangePassword Boolean             @default(true)
  lastLoginAt        DateTime?
  roleId             String
  role               Role                @relation(fields: [roleId], references: [id])
  inventoryMovements InventoryMovement[] @relation("MovementCreatedBy")
  preorders          Preorder[]          @relation("PreorderCreatedBy")
  salesBooks         SalesBook[]
  productionOrders   ProductionOrder[]   @relation("ProductionResponsible")
  dispatches         Dispatch[]          @relation("DispatchResponsible")
  driverLocations    DriverLocation[]
  dispatchReturns    DispatchReturn[]
  auditLogs          AuditLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([roleId])
}

model SalesBook {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  startNumber      Int
  endNumber        Int
  nextNumber       Int
  warningThreshold Int      @default(10)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, isActive])
  @@index([nextNumber])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique @db.VarChar(80)
  description String?          @db.VarChar(255)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique @db.VarChar(120)
  module      String           @db.VarChar(80)
  description String?          @db.VarChar(255)
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model ProductCategory {
  id       String    @id @default(cuid())
  name     String    @unique @db.VarChar(120)
  products Product[]
}

model Product {
  id                    String                  @id @default(cuid())
  sku                   String                  @unique @db.VarChar(80)
  name                  String                  @db.VarChar(180)
  color                 String?                 @db.VarChar(80)
  modelName             String?                 @db.VarChar(120)
  catalogExternalId     String?                 @db.VarChar(180)
  catalogProductId      String?                 @db.VarChar(120)
  catalogImageUrl       String?                 @db.VarChar(500)
  description           String?                 @db.Text
  priceGTQ              Decimal?                @db.Decimal(14, 2)
  type                  ProductType
  unit                  String                  @db.VarChar(20)
  minimumStock          Decimal                 @default(0) @db.Decimal(14, 3)
  categoryId            String?
  category              ProductCategory?        @relation(fields: [categoryId], references: [id])
  balances              StockBalance[]
  movements             InventoryMovement[]
  targetProductionOrders ProductionOrder[]     @relation("ProductionTargetProduct")
  preorderItems         PreorderItem[]
  productionConsumables ProductionConsumption[]
  productionOutputs     ProductionOutput[]
  dispatchItems         DispatchItem[]
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([type])
  @@index([isActive, type])
  @@index([categoryId])
  @@index([catalogExternalId])
  @@index([catalogProductId])
}

model Location {
  id                String              @id @default(cuid())
  code              String              @unique @db.VarChar(60)
  name              String              @db.VarChar(140)
  type              LocationType
  truck             Truck?
  balances          StockBalance[]
  outgoingMovements InventoryMovement[] @relation("MovementFrom")
  incomingMovements InventoryMovement[] @relation("MovementTo")
  factoryProductionOrders ProductionOrder[] @relation("ProductionDestination")
  isFactoryWarehouse Boolean             @default(false)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([type, isActive])
  @@index([isFactoryWarehouse])
}

model StockBalance {
  id         String   @id @default(cuid())
  productId  String
  locationId String
  quantity   Decimal  @default(0) @db.Decimal(14, 3)
  reserved   Decimal  @default(0) @db.Decimal(14, 3)
  product    Product  @relation(fields: [productId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([locationId])
  @@index([productId])
}

model InventoryMovement {
  id                String           @id @default(cuid())
  code              String           @unique @db.VarChar(80)
  type              MovementType
  productId         String
  fromLocationId    String?
  toLocationId      String?
  quantity          Decimal          @db.Decimal(14, 3)
  unitCost          Decimal?         @db.Decimal(14, 4)
  reason            String           @db.VarChar(255)
  reference         String?          @db.VarChar(120)
  product           Product          @relation(fields: [productId], references: [id])
  fromLocation      Location?        @relation("MovementFrom", fields: [fromLocationId], references: [id])
  toLocation        Location?        @relation("MovementTo", fields: [toLocationId], references: [id])
  preorderItemId    String?
  preorderItem      PreorderItem?    @relation(fields: [preorderItemId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  dispatchItemId    String?
  dispatchItem      DispatchItem?    @relation(fields: [dispatchItemId], references: [id])
  createdById       String
  createdBy         User             @relation("MovementCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime         @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
  @@index([productId, createdAt])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([createdById, createdAt])
  @@index([preorderItemId])
  @@index([productionOrderId])
  @@index([dispatchItemId])
}

model Client {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(180)
  taxId     String?    @db.VarChar(80)
  email     String?    @db.VarChar(160)
  phone     String?    @db.VarChar(40)
  address   String?    @db.VarChar(255)
  preorders Preorder[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([taxId])
  @@index([createdAt])
}

model Preorder {
  id          String         @id @default(cuid())
  code        String         @unique @db.VarChar(80)
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id])
  status      PreorderStatus @default(PENDING)
  deliveryAddress String?    @db.VarChar(255)
  originLocationId String?
  saleLatitude Decimal?       @db.Decimal(10, 7)
  saleLongitude Decimal?      @db.Decimal(10, 7)
  saleAccuracy Decimal?       @db.Decimal(10, 2)
  paymentMethod String?      @db.VarChar(80)
  discountGTQ Decimal        @default(0) @db.Decimal(14, 2)
  amountReceivedGTQ Decimal  @default(0) @db.Decimal(14, 2)
  totalGTQ Decimal           @default(0) @db.Decimal(14, 2)
  items       PreorderItem[]
  dispatches  Dispatch[]
  invoice     Invoice?
  createdById String
  createdBy   User           @relation("PreorderCreatedBy", fields: [createdById], references: [id])
  confirmedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([clientId])
  @@index([createdById, createdAt])
  @@index([originLocationId])
}

model PreorderItem {
  id                  String              @id @default(cuid())
  preorderId          String
  productId           String
  quantity            Decimal             @db.Decimal(14, 3)
  reservedQuantity    Decimal             @default(0) @db.Decimal(14, 3)
  unitPrice           Decimal             @db.Decimal(14, 4)
  preorder            Preorder            @relation(fields: [preorderId], references: [id])
  product             Product             @relation(fields: [productId], references: [id])
  inventoryMovements  InventoryMovement[]
  dispatchItems       DispatchItem[]

  @@index([preorderId])
  @@index([productId])
}

model ProductionOrder {
  id                 String                  @id @default(cuid())
  code               String                  @unique @db.VarChar(80)
  status             ProductionStatus        @default(PLANNED)
  shift              String                  @db.VarChar(80)
  shiftStart         String?                 @db.VarChar(20)
  shiftEnd           String?                 @db.VarChar(20)
  targetProductId    String?
  targetProduct      Product?                @relation("ProductionTargetProduct", fields: [targetProductId], references: [id])
  destinationLocationId String?
  destinationLocation   Location?            @relation("ProductionDestination", fields: [destinationLocationId], references: [id])
  plannedQuantity    Decimal                 @default(0) @db.Decimal(14, 3)
  producedQuantity   Decimal                 @default(0) @db.Decimal(14, 3)
  responsibleId      String
  responsible        User                    @relation("ProductionResponsible", fields: [responsibleId], references: [id])
  consumptions       ProductionConsumption[]
  outputs            ProductionOutput[]
  inventoryMovements InventoryMovement[]
  plannedStart       DateTime?
  plannedEnd         DateTime?
  startedAt          DateTime?
  closedAt           DateTime?
  wasteNotes         String?                 @db.VarChar(255)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([targetProductId])
  @@index([destinationLocationId])
  @@index([status, createdAt])
  @@index([responsibleId, createdAt])
}

model ShiftSchedule {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(80)
  startTime String   @db.VarChar(5)
  endTime   String   @db.VarChar(5)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model ProductionConsumption {
  id                String          @id @default(cuid())
  productionOrderId String
  productId         String
  plannedQuantity   Decimal         @db.Decimal(14, 3)
  consumedQuantity  Decimal         @default(0) @db.Decimal(14, 3)
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])
  product           Product         @relation(fields: [productId], references: [id])

  @@index([productionOrderId])
  @@index([productId])
}

model ProductionOutput {
  id                String          @id @default(cuid())
  productionOrderId String
  productId         String
  plannedQuantity   Decimal         @db.Decimal(14, 3)
  producedQuantity  Decimal         @default(0) @db.Decimal(14, 3)
  rejectedQuantity  Decimal         @default(0) @db.Decimal(14, 3)
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])
  product           Product         @relation(fields: [productId], references: [id])

  @@index([productionOrderId])
  @@index([productId])
}

model Truck {
  id          String    @id @default(cuid())
  code        String    @unique @db.VarChar(60)
  plate       String    @unique @db.VarChar(40)
  capacityKg  Decimal?  @db.Decimal(12, 3)
  locationId  String    @unique
  location    Location  @relation(fields: [locationId], references: [id])
  dispatches  Dispatch[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Dispatch {
  id            String         @id @default(cuid())
  code          String         @unique @db.VarChar(80)
  status        DispatchStatus @default(SCHEDULED)
  preorderId    String?
  preorder      Preorder?      @relation(fields: [preorderId], references: [id])
  truckId       String?
  truck         Truck?         @relation(fields: [truckId], references: [id])
  responsibleId String
  responsible   User           @relation("DispatchResponsible", fields: [responsibleId], references: [id])
  routeName     String         @db.VarChar(140)
  destination   String         @db.VarChar(255)
  destinationLatitude Decimal? @db.Decimal(10, 7)
  destinationLongitude Decimal? @db.Decimal(10, 7)
  destinationAccuracy Decimal? @db.Decimal(10, 2)
  items         DispatchItem[]
  returns       DispatchReturn[]
  scheduledAt   DateTime
  loadedAt      DateTime?
  deliveredAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([scheduledAt])
  @@index([preorderId])
  @@index([truckId])
  @@index([responsibleId, createdAt])
}

model DispatchReturn {
  id          String   @id @default(cuid())
  dispatchId  String
  dispatch    Dispatch @relation(fields: [dispatchId], references: [id])
  driverId    String
  driver      User     @relation(fields: [driverId], references: [id])
  reason      String   @db.VarChar(255)
  resolution  String?  @db.VarChar(80)
  resolvedAt  DateTime?
  items       DispatchReturnItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dispatchId])
  @@index([driverId])
}

model DispatchReturnItem {
  id               String         @id @default(cuid())
  dispatchReturnId String
  dispatchReturn   DispatchReturn @relation(fields: [dispatchReturnId], references: [id])
  dispatchItemId   String
  dispatchItem     DispatchItem   @relation(fields: [dispatchItemId], references: [id])
  quantity         Decimal        @db.Decimal(14, 3)
  createdAt        DateTime       @default(now())

  @@unique([dispatchReturnId, dispatchItemId])
  @@index([dispatchReturnId])
  @@index([dispatchItemId])
}

model Invoice {
  id        String   @id @default(cuid())
  number    String   @unique @db.VarChar(80)
  preorderId String  @unique
  preorder  Preorder @relation(fields: [preorderId], references: [id])
  companyAddress String @db.VarChar(255)
  companyPhone String @db.VarChar(80)
  totalGTQ Decimal @db.Decimal(14, 2)
  issuedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([issuedAt])
}

model DriverLocation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  accuracy  Decimal? @db.Decimal(10, 2)
  recordedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, recordedAt])
}

model DispatchItem {
  id                 String              @id @default(cuid())
  dispatchId         String
  productId          String
  preorderItemId     String?
  quantity           Decimal             @db.Decimal(14, 3)
  dispatch           Dispatch            @relation(fields: [dispatchId], references: [id])
  product            Product             @relation(fields: [productId], references: [id])
  preorderItem       PreorderItem?        @relation(fields: [preorderItemId], references: [id])
  inventoryMovements InventoryMovement[]
  returnItems        DispatchReturnItem[]

  @@index([dispatchId])
  @@index([productId])
  @@index([preorderItemId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   @db.VarChar(120)
  entity    String   @db.VarChar(120)
  entityId  String?  @db.VarChar(120)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
}

model PasswordResetRequest {
  id             String    @id @default(cuid())
  requesterEmail String    @db.VarChar(160)
  userId         String?   @db.VarChar(120)
  status         String    @default("PENDING") @db.VarChar(40)
  resolvedById   String?   @db.VarChar(120)
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([requesterEmail, createdAt])
  @@index([userId])
}
